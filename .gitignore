# Data — never committed. data/manifest.yaml + data/README.md are the
# only things tracked in this directory; the actual datasets are fetched
# at runtime via scripts/fetch_data.py.
data/raw/
data/processed/
data/interim/
data/*.parquet
data/*.csv
data/*.json

# Experiment outputs — reproducible from run.py, never committed
experiments/*/output/
experiments/**/output/

# Notebook artifacts (nbstripout handles outputs in source; this catches checkpoints)
.ipynb_checkpoints/
*-checkpoint.ipynb

# Dagster
.dagster/
tmp_dagster_*/

# Plotly / matplotlib offline caches
*.html.html

# IDE / OS
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Dagster local runtime state (NRP local dev) — never committed
dagster_home/
