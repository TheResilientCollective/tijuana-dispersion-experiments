# copy to .env
#DAGSTER_HOME=/Users/valentin/development/dev_resilient/tj_calibration/tijuana-dispersion-experiments/dagster_home
KUBERNETES_SERVICE_HOST=localhost
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY
AWS_DEFAULT_REGION=us-west-2=
S3_ENDPOINT_URL=https://oss.resilientservice.mooo.com=
DAGSTER_S3_BUCKET=test          # bucket name where Dagster persists asset values

# Slack (reused from the existing alert system)
# 30 ppb tier — informational
# 100 ppb tier — actionable
SLACK_WEBHOOK_WATCH=30
SLACK_WEBHOOK_CRITICAL=100

# K8s
# which namespace Dagster submits jobs into
NRP_NAMESPACE=ucsd-center4health
# digest-pinned image for K8sRunLauncher (e.g. registry.nrp-nautilus.io/ucsd-center4health/nrp-worker@sha256:...)
DAGSTER_IMAGE=

# PostgreSQL (required for multi-replica Dagster on K8s — see dagster.yaml)
DAGSTER_PG_USER=dagster
DAGSTER_PG_PASSWORD=
DAGSTER_PG_HOST=dagster-postgres.ucsd-center4health.svc.cluster.local
DAGSTER_PG_DB=dagster
